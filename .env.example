# AI Provider - Fill in your API key
# Groq (Recommended - free tier, Llama 3.1)
GROQ_API_KEY=gsk_your_groq_api_key_here

# OR Alibaba Qwen
# QWEN_API_KEY=your_qwen_api_key_here

# Frontend Configuration
NEXT_PUBLIC_APP_NAME=Mindy
NEXT_PUBLIC_CHAIN_NAME=Mindy
NEXT_PUBLIC_RPC_URL=http://localhost:26657
NEXT_PUBLIC_CHAIN_ID=mindy-local
NEXT_PUBLIC_EXPLORER_URL=

# Contract Addresses (auto-filled after deployment)
MINDY_VAULT_ADDRESS=
MINDY_STRATEGY_MANAGER_ADDRESS=
MINDY_SESSION_KEY_MODULE_ADDRESS=
MINDY_YIELD_ROUTER_ADDRESS=

# AI Agent Wallet (server-side only - NEVER expose in frontend)
AI_AGENT_PRIVATE_KEY=0x_your_agent_private_key_here

# Initia Configuration
INITIA_NETWORK_TYPE=testnet
INITIA_GAS_STATION_ADDRESS=
